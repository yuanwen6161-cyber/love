<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>我们的小世界</title>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@300;400;600&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Ma+Shan+Zheng&display=swap" rel="stylesheet">
<style>
:root{--bg:#0d0a12;--surface:#16111f;--surface2:#1e1729;--rose:#c8637a;--rose-light:#e8899a;--rose-dim:rgba(200,99,122,0.15);--gold:#c9a96e;--text:#e8ddd0;--text-dim:#7a6e7e;--border:rgba(200,99,122,0.2);--glow:0 0 30px rgba(200,99,122,0.25)}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
body{background:var(--bg);color:var(--text);font-family:'Noto Serif SC',serif;min-height:100vh;overflow-x:hidden;position:relative}
body::before{content:'';position:fixed;inset:0;background-image:radial-gradient(1px 1px at 15% 20%,rgba(255,255,255,.5) 0%,transparent 100%),radial-gradient(1px 1px at 40% 10%,rgba(255,255,255,.4) 0%,transparent 100%),radial-gradient(1.5px 1.5px at 70% 30%,rgba(255,255,255,.3) 0%,transparent 100%),radial-gradient(1px 1px at 85% 15%,rgba(255,255,255,.5) 0%,transparent 100%),radial-gradient(1px 1px at 25% 60%,rgba(255,255,255,.3) 0%,transparent 100%),radial-gradient(1.5px 1.5px at 55% 75%,rgba(255,255,255,.4) 0%,transparent 100%),radial-gradient(1px 1px at 90% 55%,rgba(255,255,255,.3) 0%,transparent 100%),radial-gradient(1px 1px at 10% 85%,rgba(255,255,255,.4) 0%,transparent 100%),radial-gradient(1.5px 1.5px at 35% 90%,rgba(255,255,255,.3) 0%,transparent 100%),radial-gradient(1px 1px at 65% 45%,rgba(255,255,255,.5) 0%,transparent 100%),radial-gradient(1px 1px at 78% 82%,rgba(255,255,255,.3) 0%,transparent 100%),radial-gradient(1px 1px at 48% 35%,rgba(255,255,255,.4) 0%,transparent 100%);pointer-events:none;z-index:0}
body::after{content:'';position:fixed;top:-30%;left:50%;transform:translateX(-50%);width:600px;height:400px;background:radial-gradient(ellipse,rgba(200,99,122,.08) 0%,transparent 70%);pointer-events:none;z-index:0}

/* LOCK */
#lockScreen{position:fixed;inset:0;background:var(--bg);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:1000;gap:26px;padding:40px}
.lock-icon{font-size:48px;animation:float 3s ease-in-out infinite}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
.lock-title{font-family:'Cormorant Garamond',serif;font-size:28px;font-style:italic;color:var(--rose-light);text-align:center}
.lock-subtitle{font-size:13px;color:var(--text-dim);letter-spacing:2px}
.pin-dots{display:flex;gap:16px}
.pin-dot{width:14px;height:14px;border-radius:50%;border:2px solid var(--border);transition:all .2s}
.pin-dot.filled{background:var(--rose);border-color:var(--rose);box-shadow:0 0 12px rgba(200,99,122,.6)}
.numpad{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;width:240px}
.num-btn{background:var(--surface2);border:1px solid var(--border);border-radius:50%;width:72px;height:72px;color:var(--text);font-family:'Cormorant Garamond',serif;font-size:24px;cursor:pointer;transition:all .15s;display:flex;align-items:center;justify-content:center}
.num-btn:active{background:var(--rose-dim);border-color:var(--rose);transform:scale(.95)}
.num-btn.del{font-size:20px;color:var(--text-dim)}
.lock-error{color:var(--rose);font-size:13px;height:20px;text-align:center}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-8px)}75%{transform:translateX(8px)}}

/* LOADING */
#loadingOverlay{position:fixed;inset:0;background:rgba(13,10,18,.7);display:none;align-items:center;justify-content:center;z-index:900;flex-direction:column;gap:16px;backdrop-filter:blur(4px)}
.loading-spinner{width:36px;height:36px;border:2px solid var(--border);border-top-color:var(--rose);border-radius:50%;animation:spin 0.8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.loading-text{font-size:13px;color:var(--text-dim);letter-spacing:2px}

/* TOAST */
#toast{position:fixed;bottom:110px;left:50%;transform:translateX(-50%);background:var(--surface2);border:1px solid var(--border);border-radius:20px;padding:10px 20px;font-size:13px;color:var(--text);z-index:2000;opacity:0;transition:opacity .3s;pointer-events:none;white-space:nowrap;box-shadow:var(--glow)}
#toast.show{opacity:1}

/* APP */
#app{display:none;flex-direction:column;min-height:100vh;position:relative;z-index:1}
#app.visible{display:flex}

/* HEADER */
.header{padding:52px 24px 16px;text-align:center}
.header-subtitle{font-family:'Cormorant Garamond',serif;font-size:13px;letter-spacing:4px;color:var(--gold);margin-bottom:6px;opacity:.8}
.header-title{font-family:'Ma Shan Zheng',cursive;font-size:34px;color:var(--text);line-height:1.2}
.header-title span{color:var(--rose-light)}
.header-deco{display:flex;align-items:center;justify-content:center;gap:12px;margin-top:14px;color:var(--rose);opacity:.5;font-size:12px;letter-spacing:6px}
.header-deco::before,.header-deco::after{content:'';width:60px;height:1px;background:linear-gradient(90deg,transparent,var(--rose))}
.header-deco::after{background:linear-gradient(90deg,var(--rose),transparent)}

/* TIMER */
.timer-card{margin:0 16px 18px;background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:18px 20px;text-align:center;position:relative;overflow:hidden}
.timer-card::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 0%,rgba(200,99,122,.08) 0%,transparent 70%);pointer-events:none}
.timer-name{font-family:'Ma Shan Zheng',cursive;font-size:15px;color:var(--gold);margin-bottom:10px}
.timer-label{font-size:11px;letter-spacing:3px;color:var(--text-dim);margin-bottom:8px}
.timer-row{display:flex;justify-content:center;gap:10px;margin-bottom:6px}
.timer-block{text-align:center}
.timer-num{font-family:'Cormorant Garamond',serif;font-size:34px;color:var(--rose-light);line-height:1;font-weight:300}
.timer-unit{font-size:10px;color:var(--text-dim);letter-spacing:2px;margin-top:2px}
.timer-sep{font-family:'Cormorant Garamond',serif;font-size:26px;color:var(--rose);opacity:.4;line-height:1.3}
.timer-divider{width:100%;height:1px;background:var(--border);margin:12px 0}
.timer-sub{font-size:12px;color:var(--text-dim)}
.timer-sub span{color:var(--rose-light)}

/* TABS */
.tabs{display:flex;margin:0 16px 16px;background:var(--surface);border-radius:16px;padding:4px;border:1px solid var(--border);overflow-x:auto;gap:2px;scrollbar-width:none}
.tabs::-webkit-scrollbar{display:none}
.tab{flex:0 0 auto;padding:9px 13px;text-align:center;font-size:12px;color:var(--text-dim);cursor:pointer;border-radius:12px;transition:all .3s;white-space:nowrap}
.tab.active{background:var(--rose-dim);color:var(--rose-light);border:1px solid var(--border)}

/* SECTIONS */
.section{display:none;padding:0 16px 120px;animation:fadeUp .4s ease}
.section.active{display:block}
@keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}

/* TOOLBAR */
.toolbar{display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;padding:0 2px}
.toolbar-label{font-size:12px;color:var(--text-dim);letter-spacing:1px}
.add-btn{display:flex;align-items:center;gap:6px;background:var(--rose-dim);border:1px solid var(--border);border-radius:20px;padding:8px 16px;color:var(--rose-light);font-size:13px;font-family:'Noto Serif SC',serif;cursor:pointer;transition:all .2s}
.add-btn:active{transform:scale(.97)}
#fileInput,#placeImgInput{display:none}

/* PHOTO */
.photo-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px}
.photo-card{position:relative;border-radius:16px;overflow:hidden;aspect-ratio:3/4;background:var(--surface);border:1px solid var(--border);cursor:pointer;transition:transform .2s}
.photo-card:active{transform:scale(.97)}
.photo-card img{width:100%;height:100%;object-fit:cover;display:block}
.photo-overlay{position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,rgba(13,10,18,.85));padding:24px 12px 12px}
.photo-caption{font-size:12px;color:var(--text);line-height:1.4;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.photo-date{font-size:10px;color:var(--text-dim);margin-top:2px}
.photo-delete{position:absolute;top:8px;right:8px;background:rgba(13,10,18,.7);border:none;border-radius:50%;width:28px;height:28px;color:var(--rose);font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .2s}
.photo-card.show-delete .photo-delete{opacity:1}
.empty-state{text-align:center;padding:60px 20px;color:var(--text-dim)}
.empty-state .ei{font-size:48px;margin-bottom:16px}
.empty-state p{font-size:14px;line-height:1.8}

/* MESSAGES */
.messages-list{display:flex;flex-direction:column;gap:16px}
.msg-card{background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:20px;position:relative;animation:fadeUp .3s ease}
.msg-card::before{content:'"';position:absolute;top:12px;left:16px;font-family:'Cormorant Garamond',serif;font-size:48px;color:var(--rose);opacity:.2;line-height:1}
.msg-author{font-size:11px;letter-spacing:2px;color:var(--gold);margin-bottom:8px;display:flex;align-items:center;gap:8px}
.msg-dot{width:6px;height:6px;border-radius:50%;background:var(--rose);box-shadow:0 0 6px var(--rose)}
.msg-text{font-size:15px;line-height:1.8;color:var(--text);padding-left:4px}
.msg-date{font-size:11px;color:var(--text-dim);margin-top:12px;text-align:right;font-family:'Cormorant Garamond',serif;font-style:italic}
.msg-del{position:absolute;top:12px;right:12px;background:none;border:none;color:var(--text-dim);font-size:16px;cursor:pointer;opacity:.4}
.msg-del:active{opacity:1;color:var(--rose)}

/* COMPOSE */
.compose-bar{position:fixed;bottom:0;left:0;right:0;background:linear-gradient(transparent,var(--bg) 30%);padding:20px 16px 32px;z-index:100}
.compose-who{display:flex;gap:6px;margin-bottom:8px;padding:0 4px}
.who-btn{padding:6px 14px;border-radius:20px;font-size:12px;font-family:'Noto Serif SC',serif;cursor:pointer;border:1px solid var(--border);background:var(--surface);color:var(--text-dim);transition:all .2s;letter-spacing:1px}
.who-btn.selected{background:var(--rose-dim);border-color:var(--rose);color:var(--rose-light)}
.compose-inner{background:var(--surface2);border:1px solid var(--border);border-radius:20px;padding:4px 4px 4px 16px;display:flex;align-items:flex-end;gap:8px;box-shadow:var(--glow)}
.compose-input{flex:1;background:none;border:none;outline:none;color:var(--text);font-family:'Noto Serif SC',serif;font-size:14px;padding:10px 0;resize:none;max-height:120px;line-height:1.6}
.compose-input::placeholder{color:var(--text-dim)}
.send-btn{width:40px;height:40px;border-radius:14px;background:var(--rose);border:none;color:white;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.send-btn:active{opacity:.8}

/* DATES */
.dates-list{display:flex;flex-direction:column;gap:12px;margin-bottom:16px}
.date-card{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:16px 20px;display:flex;align-items:center;gap:16px}
.date-icon{font-size:28px;flex-shrink:0}
.date-info{flex:1;min-width:0}
.date-name{font-size:15px;color:var(--text);margin-bottom:3px}
.date-val{font-family:'Cormorant Garamond',serif;font-size:13px;color:var(--gold)}
.date-countdown{font-size:12px;color:var(--rose-light);margin-top:3px}
.date-del{background:none;border:none;color:var(--text-dim);font-size:16px;cursor:pointer;opacity:.4;flex-shrink:0}
.date-del:active{opacity:1;color:var(--rose)}

/* SONGS */
.songs-list{display:flex;flex-direction:column;gap:12px;margin-bottom:16px}
.song-wrap{position:relative}
.song-card{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:16px 20px;display:flex;align-items:center;gap:16px;cursor:pointer;transition:all .2s;text-decoration:none;color:inherit}
.song-card:active{transform:scale(.98);background:var(--surface2)}
.song-vinyl{width:52px;height:52px;border-radius:50%;flex-shrink:0;background:conic-gradient(from 0deg,#1a1020,#2a1a30,#1a1020,#2a1a30,#1a1020);border:3px solid var(--border);display:flex;align-items:center;justify-content:center}
.song-vinyl.playing{animation:spin 3s linear infinite}
.song-vinyl::after{content:'';width:10px;height:10px;border-radius:50%;background:var(--bg)}
.song-info{flex:1;min-width:0}
.song-title{font-size:15px;color:var(--text);margin-bottom:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.song-artist{font-size:12px;color:var(--text-dim);letter-spacing:1px}
.song-note{font-size:11px;color:var(--rose-light);margin-top:3px;font-style:italic}
.song-arrow{color:var(--gold);opacity:.6;font-size:18px;flex-shrink:0}
.song-del{position:absolute;top:10px;right:10px;background:none;border:none;color:var(--text-dim);font-size:15px;cursor:pointer;opacity:.4;padding:4px}
.song-del:active{opacity:1;color:var(--rose)}

/* PLACES */
.places-tabs{display:flex;gap:8px;margin-bottom:16px}
.place-tab{flex:1;padding:9px;text-align:center;font-size:13px;border-radius:12px;border:1px solid var(--border);background:var(--surface);color:var(--text-dim);cursor:pointer;transition:all .2s}
.place-tab.active{background:var(--rose-dim);border-color:var(--rose);color:var(--rose-light)}
.places-sub{display:none}
.places-sub.active{display:block}
.places-list{display:flex;flex-direction:column;gap:12px}
.place-card{background:var(--surface);border:1px solid var(--border);border-radius:16px;overflow:hidden}
.place-img-wrap{width:100%;height:140px;background:var(--surface2);overflow:hidden;position:relative;cursor:pointer}
.place-img-wrap img{width:100%;height:100%;object-fit:cover;display:block}
.place-img-ph{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:40px;opacity:.3}
.place-img-add{position:absolute;bottom:8px;right:8px;background:rgba(13,10,18,.75);border:1px solid var(--border);border-radius:10px;padding:5px 10px;color:var(--text-dim);font-size:11px;cursor:pointer;letter-spacing:1px}
.place-body{padding:13px 16px;display:flex;align-items:flex-start;gap:12px}
.place-info{flex:1;min-width:0}
.place-city{font-size:16px;color:var(--text);margin-bottom:3px}
.place-note{font-size:12px;color:var(--text-dim);line-height:1.5}
.place-del{background:none;border:none;color:var(--text-dim);font-size:16px;cursor:pointer;opacity:.4;flex-shrink:0}
.place-del:active{opacity:1;color:var(--rose)}

/* BUCKET */
.bucket-list{display:flex;flex-direction:column;gap:10px}
.bucket-item{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:14px 16px;display:flex;align-items:center;gap:12px;transition:all .3s}
.bucket-item.done{opacity:.5}
.bucket-check{width:24px;height:24px;border-radius:50%;border:2px solid var(--border);flex-shrink:0;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;background:transparent;font-size:12px;color:white}
.bucket-check.checked{background:var(--rose);border-color:var(--rose)}
.bucket-text{flex:1;font-size:14px;color:var(--text);line-height:1.4}
.bucket-item.done .bucket-text{text-decoration:line-through;color:var(--text-dim)}
.bucket-sub{font-size:12px;color:var(--text-dim)}
.bucket-del{background:none;border:none;color:var(--text-dim);font-size:15px;cursor:pointer;opacity:.4}
.bucket-del:active{opacity:1;color:var(--rose)}

/* ADD FORM */
.add-form{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:16px;margin-top:4px}
.form-row{display:flex;flex-direction:column;gap:6px;margin-bottom:12px}
.form-label{font-size:11px;letter-spacing:2px;color:var(--text-dim)}
.form-input{background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-family:'Noto Serif SC',serif;font-size:14px;outline:none;width:100%;transition:border-color .2s}
.form-input:focus{border-color:var(--rose)}
.btn-full{width:100%;padding:12px;background:var(--rose);border:none;border-radius:12px;color:white;font-family:'Noto Serif SC',serif;font-size:14px;cursor:pointer;transition:opacity .2s;margin-top:4px}
.btn-full:active{opacity:.8}

/* MODALS */
.modal-bg{position:fixed;inset:0;background:rgba(13,10,18,.85);backdrop-filter:blur(8px);z-index:500;display:none;align-items:flex-end;justify-content:center}
.modal-bg.open{display:flex}
.modal-sheet{background:var(--surface2);border:1px solid var(--border);border-radius:24px 24px 0 0;width:100%;max-width:480px;padding:24px;animation:slideUp .3s ease}
@keyframes slideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
.modal-handle{width:40px;height:4px;background:var(--border);border-radius:2px;margin:0 auto 20px}
.modal-title{font-family:'Cormorant Garamond',serif;font-size:20px;font-style:italic;color:var(--rose-light);margin-bottom:16px;text-align:center}
.modal-input{width:100%;background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:12px 16px;color:var(--text);font-family:'Noto Serif SC',serif;font-size:14px;resize:none;outline:none;transition:border-color .2s;margin-bottom:10px;display:block}
.modal-input:focus{border-color:var(--rose)}
.modal-actions{display:flex;gap:12px;margin-top:6px}
.btn-cancel{flex:1;padding:12px;background:transparent;border:1px solid var(--border);border-radius:12px;color:var(--text-dim);font-family:'Noto Serif SC',serif;font-size:14px;cursor:pointer}
.btn-confirm{flex:1;padding:12px;background:var(--rose);border:none;border-radius:12px;color:white;font-family:'Noto Serif SC',serif;font-size:14px;cursor:pointer}
.btn-confirm:active{opacity:.8}

/* LIGHTBOX */
.lightbox{position:fixed;inset:0;background:rgba(0,0,0,.95);z-index:600;display:none;align-items:center;justify-content:center;flex-direction:column}
.lightbox.open{display:flex}
.lightbox img{max-width:100%;max-height:80vh;object-fit:contain;border-radius:8px}
.lightbox-caption{color:var(--text);font-size:14px;margin-top:16px;padding:0 32px;text-align:center;line-height:1.6}
.lightbox-close{position:absolute;top:52px;right:20px;background:none;border:none;color:var(--text-dim);font-size:28px;cursor:pointer}

/* PETALS */
.petal{position:fixed;pointer-events:none;z-index:9999;font-size:12px;opacity:0;animation:petalFall linear forwards}
@keyframes petalFall{0%{opacity:.6;transform:translateY(-20px) rotate(0deg)}100%{opacity:0;transform:translateY(100vh) rotate(360deg)}}
@media(max-width:360px){.num-btn{width:64px;height:64px;font-size:20px}.numpad{width:210px;gap:10px}}
</style>
</head>
<body>

<div id="loadingOverlay" style="display:none">
  <div class="loading-spinner"></div>
  <div class="loading-text">加载中...</div>
</div>
<div id="toast"></div>

<!-- LOCK -->
<div id="lockScreen">
  <div class="lock-icon">🌙</div>
  <div class="lock-title">我们的小世界</div>
  <div class="lock-subtitle">仅属于你和我</div>
  <div class="pin-dots">
    <div class="pin-dot" id="d0"></div><div class="pin-dot" id="d1"></div>
    <div class="pin-dot" id="d2"></div><div class="pin-dot" id="d3"></div>
  </div>
  <div class="lock-error" id="lockError"></div>
  <div class="numpad" id="numpad">
    <button class="num-btn" data-n="1">1</button><button class="num-btn" data-n="2">2</button><button class="num-btn" data-n="3">3</button>
    <button class="num-btn" data-n="4">4</button><button class="num-btn" data-n="5">5</button><button class="num-btn" data-n="6">6</button>
    <button class="num-btn" data-n="7">7</button><button class="num-btn" data-n="8">8</button><button class="num-btn" data-n="9">9</button>
    <button class="num-btn" data-n=""></button><button class="num-btn" data-n="0">0</button><button class="num-btn del" id="delBtn">⌫</button>
  </div>
</div>

<!-- APP -->
<div id="app">
  <div class="header">
    <div class="header-subtitle">Our Little World</div>
    <div class="header-title">我们的<span>小世界</span></div>
    <div class="header-deco">♡</div>
  </div>

  <div class="timer-card">
    <div class="timer-name">宇先生 ♡ 垣小姐</div>
    <div class="timer-label">相 恋</div>
    <div class="timer-row">
      <div class="timer-block"><div class="timer-num" id="tDays">000</div><div class="timer-unit">天</div></div>
      <div class="timer-sep">:</div>
      <div class="timer-block"><div class="timer-num" id="tHours">00</div><div class="timer-unit">时</div></div>
      <div class="timer-sep">:</div>
      <div class="timer-block"><div class="timer-num" id="tMins">00</div><div class="timer-unit">分</div></div>
      <div class="timer-sep">:</div>
      <div class="timer-block"><div class="timer-num" id="tSecs">00</div><div class="timer-unit">秒</div></div>
