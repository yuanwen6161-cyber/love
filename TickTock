<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>给宇先生的信</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    min-height: 100vh;
    background: #fff5f5;
    font-family: 'KaiTi', 'STKaiti', '楷体', 'AR PL UKai CN', serif;
    overflow-x: hidden;
    position: relative;
  }

  #hearts-canvas {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .heart-particle {
    position: absolute;
    bottom: -60px;
    animation: floatUp linear forwards;
    opacity: 0;
    will-change: transform, opacity;
  }

  .heart-particle::before {
    content: '♥';
    display: block;
  }

  @keyframes floatUp {
    0%   { transform: translateY(0) scale(1) rotate(0deg); opacity: 0; }
    10%  { opacity: var(--op); }
    80%  { opacity: var(--op); }
    100% { transform: translateY(-115vh) scale(var(--sc)) rotate(var(--ro)); opacity: 0; }
  }

  .content {
    position: relative;
    z-index: 10;
    max-width: 400px;
    margin: 0 auto;
    padding: 56px 28px 80px;
    text-align: center;
  }

  .to-name {
    font-size: 20px;
    font-weight: 900;
    color: #c0392b;
    letter-spacing: 3px;
    margin-bottom: 6px;
  }

  .counter-label {
    font-size: 17px;
    font-weight: 900;
    color: #c0392b;
    line-height: 1.75;
    margin-bottom: 22px;
  }

  .letter-body p {
    font-size: 14px;
    color: #c0392b;
    line-height: 1;
    padding: 7px 0;
    margin: 0;
    word-break: keep-all;
    overflow-wrap: break-word;
    white-space: normal;
  }

  .letter-body p.sm {
    font-size: 13px;
    opacity: 0.88;
  }

  .signature {
    margin-top: 28px;
    font-size: 14px;
    font-weight: 700;
    color: #c0392b;
  }
</style>
</head>
<body>

<div id="hearts-canvas"></div>

<div class="content">
  <div class="to-name">宇先生</div>

  <div class="counter-label">
    咱俩已经认识<br>
    <span id="kd">0</span>天<span id="kh">0</span>小时<span id="km">0</span>分<span id="ks">0</span>秒了<br>
    相恋了<span id="ld">0</span>天<span id="lh">0</span>小时<span id="lm">0</span>分<span id="ls">0</span>秒
  </div>

  <div class="letter-body">
    <p>还记得那天，你说「同桃城互关👋」嘛。</p>
    <p>嘿嘿，那是我们刚认识的那天。</p>
    <p>后来，我发现宝宝好有意思，有少年感又不失稳重。</p>
    <p class="sm">哈哈（悄咪咪🤫说）爸爸把我本性挖掘的很彻底嘛，太懂我啦嘻嘻。</p>
    <p>我们以后不要分开了好不好，我想陪你到 100 岁。</p>
    <p>你永远是我的宝贝，以后我要让你天天都开心。</p>
    <p>我宠着你❤️</p>
    <p>在你没抛弃我之前，我每一刻都是爱你哒。</p>
    <p>我有太多的话想和你说，太多的事想和你做。</p>
    <p>我还想给爸爸做饭吃呢～</p>
    <p>陪爸爸一起吃饭、睡觉、逛街、旅游～</p>
    <p>饭后一起去遛弯，或者打游戏也很幸福呀。</p>
    <p>和你在一起的每一秒，幸福感都溢出来啦。</p>
    <p>虽然现在不能陪在你身边，但是以后一定会让你幸福。</p>
    <p>等结束异地，我们可以等到的对吧🥺</p>
    <p>我不在的时候，一定要想我哦。</p>
    <p>希望中间的计时器，永远不要停，直至数据溢出。</p>
  </div>

  <div class="signature">——爱你的原文</div>
</div>

<script>
const knowTime = new Date('2025-10-04T16:00:00');
const loveTime = new Date('2025-10-06T00:00:00');

function calcDiff(start) {
  let diff = Math.max(0, Math.floor((Date.now() - start) / 1000));
  return [
    Math.floor(diff / 86400),
    Math.floor((diff % 86400) / 3600),
    Math.floor((diff % 3600) / 60),
    diff % 60
  ];
}

function tick() {
  const [kd,kh,km,ks] = calcDiff(knowTime);
  document.getElementById('kd').textContent = kd;
  document.getElementById('kh').textContent = kh;
  document.getElementById('km').textContent = km;
  document.getElementById('ks').textContent = ks;
  const [ld,lh,lm,ls] = calcDiff(loveTime);
  document.getElementById('ld').textContent = ld;
  document.getElementById('lh').textContent = lh;
  document.getElementById('lm').textContent = lm;
  document.getElementById('ls').textContent = ls;
}
tick();
setInterval(tick, 1000);

const canvas = document.getElementById('hearts-canvas');
const COLORS = [
  'rgba(200,40,40,OP)',
  'rgba(220,80,80,OP)',
  'rgba(235,120,120,OP)',
  'rgba(255,160,160,OP)',
  'rgba(255,185,185,OP)',
  'rgba(255,205,205,OP)',
];

function rand(a, b) { return a + Math.random() * (b - a); }

function spawnHeart() {
  const el = document.createElement('div');
  el.className = 'heart-particle';
  const size = rand(10, 46);
  const op   = rand(0.2, 0.8).toFixed(2);
  const dur  = rand(6000, 11000);
  const del  = rand(0, 800);
  const sc   = rand(0.7, 1.35).toFixed(2);
  const ro   = rand(-25, 25).toFixed(1) + 'deg';
  const col  = COLORS[Math.floor(Math.random() * COLORS.length)].replace('OP', op);
  el.style.cssText = `
    left:${rand(1,99).toFixed(1)}%;
    font-size:${size.toFixed(0)}px;
    color:${col};
    --op:${op};--sc:${sc};--ro:${ro};
    animation-duration:${dur.toFixed(0)}ms;
    animation-delay:${del.toFixed(0)}ms;
  `;
  canvas.appendChild(el);
  setTimeout(() => el.remove(), dur + del + 300);
}

for (let i = 0; i < 14; i++) setTimeout(spawnHeart, i * 280);
(function loop() { spawnHeart(); setTimeout(loop, rand(450, 850)); })();
</script>
</body>
</html>
